@page
@model MSMES.Web.Pages.AccessDeniedModel
@{
    Layout = null;
    ViewData["Title"] = "접근 권한 없음";
}
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>403 접근 권한 없음 - MSMES</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        html, body {
            height: 100%;
            font-family: 'Noto Sans KR', system-ui, sans-serif;
            font-size: 14px;
            background-color: #f5f7fa;
            margin: 0;
        }
        .error-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .error-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
            padding: 3rem 2.5rem;
            max-width: 480px;
            width: 100%;
            text-align: center;
        }
        .error-icon {
            font-size: 4rem;
            color: #dc3545;
            margin-bottom: 1rem;
        }
        .error-code {
            font-size: 3.5rem;
            font-weight: 700;
            color: #1e2a3a;
            line-height: 1;
            margin-bottom: 0.5rem;
        }
        .error-title {
            font-size: 1.2rem;
            font-weight: 600;
            color: #3c4858;
            margin-bottom: 0.75rem;
        }
        .error-desc {
            font-size: 0.9rem;
            color: #6c757d;
            margin-bottom: 2rem;
        }
    </style>
</head>
<body>
<div class="error-wrapper">
    <div class="error-card">
        <div class="error-icon"><i class="bi bi-shield-x"></i></div>
        <div class="error-code">403</div>
        <div class="error-title">접근 권한이 없습니다</div>
        <p class="error-desc">
            이 페이지에 접근하기 위한 권한이 없습니다.<br />
            필요한 경우 관리자에게 권한 부여를 요청하세요.
        </p>
        <div class="d-flex gap-2 justify-content-center flex-wrap">
            <button type="button" class="btn btn-outline-secondary" onclick="history.back()">
                <i class="bi bi-arrow-left me-1"></i> 이전 페이지로
            </button>
            <a href="/" class="btn btn-primary" style="background-color:#1a73e8; border-color:#1a73e8;">
                <i class="bi bi-house me-1"></i> 대시보드로
            </a>
        </div>
        <div class="mt-4" style="font-size:0.75rem; color:#adb5bd;">MSMES v1.0</div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmUXCfAA3oGMlX2F8vaXIbAZLkJ" crossorigin="anonymous"></script>
</body>
</html>
