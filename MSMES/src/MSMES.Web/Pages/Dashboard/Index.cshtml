@page
@model MSMES.Web.Pages.Dashboard.IndexModel
@{ ViewData["Title"] = "MES 대시보드"; }

<style>
    .kpi-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 16px; }
    .kpi-grid-sub { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 28px; }
    .kpi-card { background: #fff; border-radius: 8px; padding: 20px 24px; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
    .kpi-card .kpi-label { font-size: 0.82rem; color: #888; margin-bottom: 4px; }
    .kpi-card .kpi-value { font-size: 1.9rem; font-weight: 700; color: #2c3e50; display: flex; align-items: center; gap: 8px; }
    .kpi-card .kpi-sub   { font-size: 0.78rem; color: #aaa; margin-top: 2px; }
    .kpi-trend-up   { color: #27ae60; font-size: 1.1rem; }
    .kpi-trend-down { color: #e74c3c; font-size: 1.1rem; }
    .charts-row { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 16px; margin-bottom: 28px; }
    .chart-card { background: #fff; border-radius: 8px; padding: 20px; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
    .chart-card h3 { margin: 0 0 14px; font-size: 1rem; color: #555; }
    .section-title { font-size: 1rem; font-weight: 600; color: #2c3e50; margin-bottom: 12px; }
    .recent-table { width: 100%; border-collapse: collapse; background: #fff; border-radius: 8px; overflow: hidden; box-shadow: 0 1px 4px rgba(0,0,0,.08); }
    .recent-table th, .recent-table td { padding: 9px 14px; border-bottom: 1px solid #f0f2f5; text-align: left; font-size: 0.88rem; }
    .recent-table th { background: #f8f9fb; color: #888; font-weight: 600; }
    .badge { display: inline-block; padding: 2px 9px; border-radius: 10px; font-size: 0.75rem; font-weight: 600; }
    .badge-0, .badge-1 { background: #e3f2fd; color: #1565c0; }
    .badge-2 { background: #fff3e0; color: #e65100; }
    .badge-3, .badge-4 { background: #e8f5e9; color: #2e7d32; }
    #loading { text-align: center; padding: 40px; color: #aaa; font-size: 0.95rem; }
    #error-msg { color: #e74c3c; background: #fdf3f3; border: 1px solid #f5c6cb; border-radius: 4px; padding: 12px 16px; display: none; margin-bottom: 16px; }
</style>

<div style="display:flex;align-items:center;gap:10px;margin-bottom:4px;">
    <h1 style="margin:0;">MES 대시보드</h1>
    <span id="refresh-spinner" class="spinner-border spinner-border-sm text-primary ms-2" style="display:none;"></span>
</div>
<div id="last-updated" class="text-muted small mb-3" style="text-align:right;"></div>

<div id="error-msg"></div>
<div id="loading">데이터를 불러오는 중...</div>
<div id="dashboard-content" style="display:none;">

    <!-- KPI 핵심 4개 -->
    <div class="kpi-grid">
        <div class="kpi-card">
            <div class="kpi-label"><i class="bi bi-file-earmark-check me-1"></i>수주 잔량</div>
            <div class="kpi-value" id="kpi-so-count">-</div>
            <div class="kpi-sub">금액: <span id="kpi-so-amount">-</span></div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label"><i class="bi bi-gear me-1"></i>진행중 작업지시</div>
            <div class="kpi-value" id="kpi-wo-inprogress">-</div>
            <div class="kpi-sub">계획 <span id="kpi-wo-planned">-</span>건 / 완료 <span id="kpi-wo-completed">-</span>건</div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label"><i class="bi bi-box-seam me-1"></i>금일 생산량</div>
            <div class="kpi-value">
                <span id="kpi-produced">-</span>
                <span id="kpi-produced-trend"></span>
            </div>
            <div class="kpi-sub">목표: <span id="kpi-target">-</span></div>
            <div class="progress mt-2" style="height:4px;">
                <div class="progress-bar bg-primary" id="kpi-progress-bar" style="width:0%"></div>
            </div>
            <div id="kpi-achieve-pct" style="font-size:.75rem;color:#aaa;margin-top:3px;"></div>
        </div>
        <div class="kpi-card" id="kpi-card-stock">
            <div class="kpi-label"><i class="bi bi-exclamation-triangle me-1 text-warning"></i>재고 부족</div>
            <div class="kpi-value" id="kpi-stock-low">-</div>
            <div class="kpi-sub">소진: <span id="kpi-stock-out">-</span>건 | 부족: <span id="kpi-stock-warning">-</span>건</div>
        </div>
    </div>

    <!-- KPI 보조 3개 -->
    <div class="kpi-grid-sub">
        <div class="kpi-card">
            <div class="kpi-label">금일 불량수량</div>
            <div class="kpi-value" id="kpi-defect">-</div>
            <div class="kpi-sub">불량률: <span id="kpi-defect-rate">-</span></div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">설비 가동율</div>
            <div class="kpi-value" id="kpi-eq-running">-</div>
            <div class="kpi-sub">점검: <span id="kpi-eq-maint">-</span>  고장: <span id="kpi-eq-break">-</span></div>
        </div>
        <div class="kpi-card">
            <div class="kpi-label">7일 불량률</div>
            <div class="kpi-value" id="kpi-week-defect">-</div>
            <div class="kpi-sub">최근 7일 평균</div>
        </div>
    </div>

    <!-- 차트 영역 (3컬럼: 생산 추이 / 설비 도넛 / 달성률 게이지) -->
    <div class="charts-row">
        <div class="chart-card">
            <h3>일별 생산 추이 (최근 7일)</h3>
            <canvas id="chart-production" height="90"></canvas>
        </div>
        <div class="chart-card">
            <h3>설비 상태 분포</h3>
            <canvas id="chart-equipment" height="160"></canvas>
        </div>
        <div class="chart-card" style="display:flex;flex-direction:column;align-items:center;">
            <h3 style="width:100%;">금일 생산 달성률</h3>
            <canvas id="chart-gauge" height="160"></canvas>
            <div id="gauge-pct" style="text-align:center;font-size:1.8rem;font-weight:700;margin-top:-30px;"></div>
        </div>
    </div>

    <!-- 최근 작업지시 -->
    <div class="section-title">최근 작업지시</div>
    <table class="recent-table">
        <thead>
            <tr>
                <th>작업지시번호</th>
                <th>품목코드</th>
                <th>계획수량</th>
                <th>상태</th>
                <th>등록일시</th>
            </tr>
        </thead>
        <tbody id="recent-wo-body">
        </tbody>
    </table>

    <!-- 최근 알람 -->
    <div class="section-title mt-4">최근 알람</div>
    <div id="recent-alerts"><!-- JS로 로드 --></div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<script>
(function () {
    const loading   = document.getElementById('loading');
    const content   = document.getElementById('dashboard-content');
    const errMsg    = document.getElementById('error-msg');
    const spinner   = document.getElementById('refresh-spinner');
    const lastUpd   = document.getElementById('last-updated');

    // Chart instances — kept so they can be destroyed on refresh
    let chartProduction = null;
    let chartEquipment  = null;
    let chartGauge      = null;

    function fmt(n)      { return Number(n).toLocaleString('ko-KR'); }
    function fmtMoney(n) { return '₩' + Number(n).toLocaleString('ko-KR'); }

    async function loadDashboard() {
        spinner.style.display = 'inline-block';
        try {
            const resp = await fetch('/api/dashboard');
            if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
            const data = await resp.json();
            renderDashboard(data);
            errMsg.style.display = 'none';
        } catch (e) {
            errMsg.style.display = 'block';
            errMsg.textContent   = '대시보드 데이터를 불러오지 못했습니다: ' + e.message;
        } finally {
            spinner.style.display = 'none';
        }
    }

    function renderDashboard(data) {
        const kpi = data.kpi;

        // --- KPI 채우기 ---
        document.getElementById('kpi-produced').textContent = fmt(kpi.todayProduced);
        document.getElementById('kpi-target').textContent   = fmt(kpi.todayTarget);

        // 목표 대비 추세 화살표
        const trendEl = document.getElementById('kpi-produced-trend');
        if (kpi.todayProduced > kpi.todayTarget * 0.8) {
            trendEl.textContent  = '▲';
            trendEl.className    = 'kpi-trend-up';
        } else {
            trendEl.textContent  = '▼';
            trendEl.className    = 'kpi-trend-down';
        }

        // 진행 바 & 달성률 텍스트
        const target      = kpi.todayTarget || 1;
        const achievePct  = Math.min(100, Math.round(kpi.todayProduced / target * 100));
        document.getElementById('kpi-progress-bar').style.width = achievePct + '%';
        document.getElementById('kpi-achieve-pct').textContent  = '목표 달성률: ' + achievePct + '%';

        document.getElementById('kpi-defect').textContent     = fmt(kpi.todayDefect);
        const defRate = kpi.todayProduced > 0
            ? (kpi.todayDefect / kpi.todayProduced * 100).toFixed(1) + '%'
            : '0%';
        document.getElementById('kpi-defect-rate').textContent = defRate;

        // 핵심 KPI: 수주 잔량
        document.getElementById('kpi-so-count').textContent    = fmt(kpi.openSalesOrderCount) + ' 건';
        document.getElementById('kpi-so-amount').textContent   = fmtMoney(kpi.openSalesOrderAmount);

        // 핵심 KPI: 진행중 작업지시
        document.getElementById('kpi-wo-inprogress').textContent = kpi.workOrderInProgress + ' 건';
        document.getElementById('kpi-wo-planned').textContent    = fmt(kpi.workOrderPlanned);
        document.getElementById('kpi-wo-completed').textContent  = fmt(kpi.workOrderCompleted);

        // 핵심 KPI: 재고 부족
        const stockLow  = kpi.inventoryLow  ?? 0;
        const stockOut  = kpi.inventoryOut  ?? 0;
        const stockTotal = stockLow + stockOut;
        document.getElementById('kpi-stock-low').textContent     = stockTotal + ' 건';
        document.getElementById('kpi-stock-out').textContent     = stockOut;
        document.getElementById('kpi-stock-warning').textContent = stockLow;
        // 재고 부족이 있으면 카드 강조
        const stockCard = document.getElementById('kpi-card-stock');
        if (stockTotal > 0) stockCard.style.borderTop = '3px solid #f39c12';

        document.getElementById('kpi-eq-running').textContent  = kpi.equipmentRunning + ' 대';
        document.getElementById('kpi-eq-maint').textContent    = kpi.equipmentMaintenance;
        document.getElementById('kpi-eq-break').textContent    = kpi.equipmentBreakdown;
        document.getElementById('kpi-week-defect').textContent =
            (kpi.recent7DaysDefectRate ?? 0).toFixed(1) + '%';

        // --- 생산 라인차트 ---
        const chart  = data.productionChart;
        const labels = chart.dates.map(d => d.substring(0, 10));

        if (chartProduction) chartProduction.destroy();
        chartProduction = new Chart(document.getElementById('chart-production'), {
            type: 'line',
            data: {
                labels,
                datasets: [
                    { label: '생산량', data: chart.produced, borderColor: '#3498db', backgroundColor: 'rgba(52,152,219,.15)', tension: 0.3, fill: true },
                    { label: '불량량', data: chart.defect,   borderColor: '#e74c3c', backgroundColor: 'rgba(231,76,60,.10)',   tension: 0.3, fill: true }
                ]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });

        // --- 설비 도넛차트 ---
        if (chartEquipment) chartEquipment.destroy();
        chartEquipment = new Chart(document.getElementById('chart-equipment'), {
            type: 'doughnut',
            data: {
                labels: ['가동중', '정지', '점검중', '고장'],
                datasets: [{
                    data: [kpi.equipmentRunning, kpi.equipmentStopped, kpi.equipmentMaintenance, kpi.equipmentBreakdown],
                    backgroundColor: ['#27ae60', '#95a5a6', '#f39c12', '#e74c3c']
                }]
            },
            options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
        });

        // --- 달성률 게이지 (반원 도넛) ---
        const pct = Math.min(100, Math.round(kpi.todayProduced / (kpi.todayTarget || 1) * 100));
        const gaugeColor = pct >= 80 ? '#27ae60' : pct >= 50 ? '#f39c12' : '#e74c3c';
        document.getElementById('gauge-pct').textContent = pct + '%';
        document.getElementById('gauge-pct').style.color = gaugeColor;

        if (chartGauge) chartGauge.destroy();
        chartGauge = new Chart(document.getElementById('chart-gauge'), {
            type: 'doughnut',
            data: {
                datasets: [{
                    data: [pct, 100 - pct],
                    backgroundColor: [gaugeColor, '#f0f2f5'],
                    borderWidth: 0
                }]
            },
            options: {
                circumference: 180,
                rotation: -90,
                cutout: '75%',
                plugins: { legend: { display: false }, tooltip: { enabled: false } }
            }
        });

        // --- 최근 작업지시 ---
        const tbody      = document.getElementById('recent-wo-body');
        tbody.innerHTML  = '';
        const statusNames = { '0': '계획', '1': '릴리즈', '2': '진행중', '3': '완료', '4': '마감' };
        for (const wo of data.recentWorkOrders) {
            const tr = document.createElement('tr');
            const statusClass = 'badge-' + wo.status;
            tr.innerHTML = `
                <td>${wo.workOrderNo}</td>
                <td>${wo.itemCode}</td>
                <td>${fmt(wo.quantity)}</td>
                <td><span class="badge ${statusClass}">${statusNames[wo.status] ?? wo.status}</span></td>
                <td>${new Date(wo.createdAt).toLocaleString('ko-KR')}</td>`;
            tbody.appendChild(tr);
        }

        // 최종 갱신 시각
        lastUpd.textContent = '최종 갱신: ' + new Date().toLocaleTimeString('ko-KR');
    }

    async function loadAlerts() {
        try {
            // 상위 3건 알림 (실시간 쿼리 기반)
            const r      = await fetch('/api/dashboard/alerts');
            if (!r.ok) return;
            const alerts = await r.json();
            const div    = document.getElementById('recent-alerts');

            const severityLabel = { 3: '위험', 2: '경고', 1: '정보' };
            const cssClass      = { 3: 'danger', 2: 'warning', 1: 'info' };

            if (!alerts.length) {
                div.innerHTML = `
                    <div style="background:#fff;border-radius:8px;padding:20px;text-align:center;color:#aaa;box-shadow:0 1px 4px rgba(0,0,0,.06)">
                        <i class="bi bi-check-circle text-success me-1"></i>모든 항목이 정상입니다
                    </div>`;
                return;
            }
            div.innerHTML = alerts.map(a => `
                <div style="display:flex;align-items:center;gap:10px;padding:10px 14px;background:#fff;border-radius:8px;margin-bottom:8px;box-shadow:0 1px 4px rgba(0,0,0,.06);border-left:4px solid var(--bs-${cssClass[a.severity] ?? 'secondary'});">
                    <i class="bi ${a.alertTypeIcon} text-${cssClass[a.severity] ?? 'secondary'} fs-5"></i>
                    <div style="flex:1;">
                        <div style="font-size:.86rem;font-weight:600;color:#2c3e50;">${a.title}</div>
                        <div style="font-size:.78rem;color:#aaa;">${a.message ?? ''}</div>
                    </div>
                    <span class="badge bg-${cssClass[a.severity] ?? 'secondary'}">${severityLabel[a.severity] ?? '정보'}</span>
                    <a href="${a.linkUrl ?? '/Alerts'}" style="font-size:.75rem;color:#1a73e8;white-space:nowrap;">상세보기</a>
                </div>`).join('');

            // 헤더 뱃지도 함께 업데이트 (count API 호출)
            const countRes = await fetch('/api/alerts/count');
            if (countRes.ok) {
                const { total } = await countRes.json();
                const badge = document.getElementById('alert-badge');
                if (badge) badge.textContent = total > 0 ? total : '';
            }
        } catch (_) { /* 알람 로드 실패는 무시 */ }
    }

    async function loadAll() {
        await Promise.all([loadDashboard(), loadAlerts()]);
    }

    // 최초 로드
    loadAll().then(() => {
        loading.style.display  = 'none';
        content.style.display  = 'block';

        // 30초마다 자동 갱신
        setTimeout(function autoRefresh() {
            loadAll().then(() => setTimeout(autoRefresh, 30000));
        }, 30000);
    });
})();
</script>
