@page
@model MSMES.Web.Pages.Alerts.IndexModel
@{ ViewData["Title"] = "알람/경보"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">알람 / 경보</h1>
    <a href="?showResolved=@(!Model.ShowResolved)" class="btn btn-outline-secondary btn-sm">
        @(Model.ShowResolved ? "미해결만 보기" : "해결된 항목 포함")
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card border-danger border-0 shadow-sm text-center py-3">
            <div class="text-danger small fw-semibold">위험</div>
            <div class="h2 fw-bold text-danger mb-0">@Model.DangerCount</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="text-warning small fw-semibold">경고</div>
            <div class="h2 fw-bold text-warning mb-0">@Model.WarningCount</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="text-muted small fw-semibold">미확인</div>
            <div class="h2 fw-bold mb-0">@Model.UnreadCount</div>
        </div>
    </div>
</div>

<div class="d-flex flex-column gap-3">
@foreach (var alert in Model.Alerts)
{
    <div class="card border-0 shadow-sm @(alert.IsResolved ? "opacity-50" : "") @(!alert.IsRead && !alert.IsResolved ? "border-start border-4 border-" + alert.SeverityCss : "")">
        <div class="card-body d-flex align-items-start gap-3">
            <div class="flex-shrink-0 mt-1">
                <i class="bi @alert.AlertTypeIcon fs-4 text-@alert.SeverityCss"></i>
            </div>
            <div class="flex-grow-1">
                <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="badge bg-@alert.SeverityCss">@alert.SeverityName</span>
                    @if (!alert.IsRead && !alert.IsResolved)
                    {
                        <span class="badge bg-dark">NEW</span>
                    }
                    @if (alert.IsResolved)
                    {
                        <span class="badge bg-secondary">해결됨</span>
                    }
                    <span class="text-muted small ms-auto">@alert.CreatedAt.ToLocalTime().ToString("MM/dd HH:mm")</span>
                </div>
                <div class="fw-semibold mb-1">@alert.Title</div>
                <div class="text-muted small">@alert.Message</div>
            </div>
            @if (!alert.IsResolved)
            {
                <div class="flex-shrink-0 d-flex gap-1">
                    @if (!alert.IsRead)
                    {
                        <button class="btn btn-sm btn-outline-secondary" onclick="markRead(@alert.Id, this)">확인</button>
                    }
                    <button class="btn btn-sm btn-outline-success" onclick="resolve(@alert.Id, this)">해결</button>
                </div>
            }
        </div>
    </div>
}
@if (!Model.Alerts.Any())
{
    <div class="card border-0 shadow-sm">
        <div class="card-body text-center text-muted py-5">
            <i class="bi bi-check-circle fs-1 d-block mb-2 text-success"></i>
            알람이 없습니다.
        </div>
    </div>
}
</div>

@section Scripts {
<script>
async function markRead(id, btn) {
    await fetch(`/api/alerts/${id}/read`, { method: 'POST' });
    btn.closest('.card').querySelector('.badge.bg-dark')?.remove();
    btn.remove();
    updateBadge();
}
async function resolve(id, btn) {
    await fetch(`/api/alerts/${id}/resolve`, { method: 'POST' });
    btn.closest('.card').classList.add('opacity-50');
    btn.closest('.d-flex.gap-1').innerHTML = '<span class="badge bg-secondary">해결됨</span>';
    updateBadge();
}
async function updateBadge() {
    const r = await fetch('/api/alerts/count');
    const { count } = await r.json();
    const badge = document.getElementById('alert-badge');
    if (badge) badge.textContent = count > 0 ? count : '';
}
</script>
}
