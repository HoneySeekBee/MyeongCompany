@page
@model MSMES.Web.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>로그인 - MSMES</title>

    <!-- Google Fonts: Noto Sans KR -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Bootstrap 5.3 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />

    <!-- Bootstrap Icons 1.11 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        :root {
            --ms-primary:  #1a73e8;
            --ms-dark:     #1e2a3a;
            --ms-dark-2:   #27374d;
            --ms-bg:       #f5f7fa;
        }

        *, *::before, *::after { box-sizing: border-box; }

        html, body {
            height: 100%;
            font-family: 'Noto Sans KR', system-ui, -apple-system, 'Segoe UI', sans-serif;
            font-size: 14px;
            margin: 0;
            background-color: var(--ms-bg);
        }

        /* ── 전체 레이아웃 ────────────────────────────────── */
        .login-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* ── 좌측 브랜드 패널 ────────────────────────────── */
        .login-brand {
            flex: 0 0 45%;
            background: linear-gradient(145deg, var(--ms-dark) 0%, var(--ms-dark-2) 60%, #1a4a7a 100%);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem 2.5rem;
            color: #fff;
            position: relative;
            overflow: hidden;
        }

        .login-brand::before {
            content: '';
            position: absolute;
            top: -80px;
            right: -80px;
            width: 320px;
            height: 320px;
            border-radius: 50%;
            background: rgba(26, 115, 232, 0.12);
        }

        .login-brand::after {
            content: '';
            position: absolute;
            bottom: -60px;
            left: -60px;
            width: 240px;
            height: 240px;
            border-radius: 50%;
            background: rgba(26, 115, 232, 0.08);
        }

        .login-brand__inner {
            position: relative;
            z-index: 1;
            text-align: center;
        }

        .login-brand__icon {
            width: 80px;
            height: 80px;
            background: rgba(26, 115, 232, 0.25);
            border-radius: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2.5rem;
            border: 1px solid rgba(255,255,255,0.15);
        }

        .login-brand__logo {
            font-size: 2.2rem;
            font-weight: 700;
            letter-spacing: 3px;
            color: #fff;
            margin-bottom: 0.5rem;
        }

        .login-brand__slogan {
            font-size: 0.9rem;
            color: rgba(255, 255, 255, 0.7);
            letter-spacing: 1px;
            font-weight: 300;
            margin-bottom: 2.5rem;
        }

        .login-brand__features {
            list-style: none;
            padding: 0;
            margin: 0;
            text-align: left;
            width: 100%;
            max-width: 280px;
        }

        .login-brand__features li {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.6rem 0;
            font-size: 0.85rem;
            color: rgba(255,255,255,0.75);
            border-bottom: 1px solid rgba(255,255,255,0.07);
        }

        .login-brand__features li:last-child {
            border-bottom: none;
        }

        .login-brand__features .bi {
            color: var(--ms-primary);
            font-size: 1rem;
            flex-shrink: 0;
        }

        /* ── 우측 로그인 카드 영역 ───────────────────────── */
        .login-right {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 2rem 1.5rem;
            background-color: var(--ms-bg);
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
            padding: 2.5rem 2rem;
        }

        .login-card__title {
            font-size: 1.5rem;
            font-weight: 700;
            color: #1e2a3a;
            margin-bottom: 0.25rem;
        }

        .login-card__subtitle {
            font-size: 0.85rem;
            color: #6c757d;
            margin-bottom: 2rem;
        }

        .login-card .form-label {
            font-weight: 500;
            color: #3c4858;
            margin-bottom: 0.4rem;
            font-size: 0.85rem;
        }

        .login-card .input-group-text {
            background-color: #f5f7fa;
            border-right: none;
            color: #6c757d;
        }

        .login-card .form-control {
            border-left: none;
        }

        .login-card .form-control:focus {
            border-color: #ced4da;
            box-shadow: none;
        }

        .login-card .input-group:focus-within .input-group-text,
        .login-card .input-group:focus-within .form-control {
            border-color: var(--ms-primary);
        }

        .btn-login {
            background-color: var(--ms-primary);
            border-color: var(--ms-primary);
            color: #fff;
            font-weight: 600;
            font-size: 0.95rem;
            padding: 0.65rem 1rem;
            border-radius: 8px;
            transition: background-color 0.2s ease;
        }

        .btn-login:hover {
            background-color: #1557b0;
            border-color: #1557b0;
            color: #fff;
        }

        .btn-toggle-pw {
            border-left: none;
            background-color: #f5f7fa;
            color: #6c757d;
            cursor: pointer;
        }

        .btn-toggle-pw:hover {
            color: #1e2a3a;
        }

        .login-version {
            font-size: 0.75rem;
            color: #adb5bd;
            text-align: center;
            margin-top: 1.5rem;
        }

        /* ── 반응형 ──────────────────────────────────────── */
        @@media (max-width: 768px) {
            .login-brand {
                display: none;
            }
            .login-right {
                justify-content: center;
            }
        }
    </style>
</head>
<body>

<div class="login-wrapper">

    <!-- 좌측: 브랜드 패널 -->
    <div class="login-brand">
        <div class="login-brand__inner">
            <div class="login-brand__icon">
                <i class="bi bi-cpu"></i>
            </div>
            <div class="login-brand__logo">MSMES</div>
            <div class="login-brand__slogan">Manufacturing Execution System</div>

            <ul class="login-brand__features">
                <li><i class="bi bi-speedometer2"></i> 실시간 생산 현황 대시보드</li>
                <li><i class="bi bi-gear"></i> 작업지시 및 공정관리</li>
                <li><i class="bi bi-box-seam"></i> 재고 · 출하 통합 관리</li>
                <li><i class="bi bi-patch-check"></i> 품질검사 및 설비관리</li>
                <li><i class="bi bi-tags"></i> LOT 추적 및 이력관리</li>
            </ul>
        </div>
    </div>

    <!-- 우측: 로그인 폼 -->
    <div class="login-right">
        <div class="login-card">
            <h1 class="login-card__title">로그인</h1>
            <p class="login-card__subtitle">MSMES 계정으로 로그인하세요.</p>

            <!-- 오류 메시지 영역 -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger d-flex align-items-center gap-2 py-2" role="alert">
                    <i class="bi bi-exclamation-triangle-fill flex-shrink-0"></i>
                    <div>
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                </div>
            }

            <form method="post">
                @Html.AntiForgeryToken()

                <!-- 아이디 -->
                <div class="mb-3">
                    <label for="UserId" class="form-label">아이디</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-person"></i></span>
                        <input type="text" id="UserId" name="UserId" class="form-control"
                               placeholder="아이디를 입력하세요" value="@Model.UserId"
                               autocomplete="username" autofocus required />
                    </div>
                </div>

                <!-- 비밀번호 -->
                <div class="mb-4">
                    <label for="Password" class="form-label">비밀번호</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-lock"></i></span>
                        <input type="password" id="Password" name="Password" class="form-control"
                               placeholder="비밀번호를 입력하세요"
                               autocomplete="current-password" required />
                        <button type="button" class="btn btn-outline-secondary btn-toggle-pw"
                                id="btnTogglePw" aria-label="비밀번호 표시/숨기기" title="비밀번호 표시/숨기기">
                            <i class="bi bi-eye" id="pwIcon"></i>
                        </button>
                    </div>
                </div>

                <!-- 로그인 버튼 -->
                <div class="d-grid">
                    <button type="submit" class="btn btn-login">
                        <i class="bi bi-box-arrow-in-right me-1"></i> 로그인
                    </button>
                </div>
            </form>

            <div class="login-version">MSMES v1.0</div>
        </div>
    </div>

</div>

<!-- Bootstrap 5.3 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmUXCfAA3oGMlX2F8vaXIbAZLkJ" crossorigin="anonymous"></script>

<script>
    (function () {
        var btn = document.getElementById('btnTogglePw');
        var input = document.getElementById('Password');
        var icon = document.getElementById('pwIcon');
        if (btn && input && icon) {
            btn.addEventListener('click', function () {
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.className = 'bi bi-eye-slash';
                } else {
                    input.type = 'password';
                    icon.className = 'bi bi-eye';
                }
            });
        }
    })();
</script>
</body>
</html>
