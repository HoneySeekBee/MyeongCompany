@page
@model MSMES.Web.Pages.ErrorModel
@{
    Layout = null;
    ViewData["Title"] = "오류가 발생했습니다";
}
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>500 서버 오류 - MSMES</title>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

    <style>
        html, body {
            height: 100%;
            font-family: 'Noto Sans KR', system-ui, sans-serif;
            font-size: 14px;
            background-color: #f5f7fa;
            margin: 0;
        }
        .error-wrapper {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .error-card {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.08);
            padding: 3rem 2.5rem;
            max-width: 560px;
            width: 100%;
            text-align: center;
        }
        .error-icon {
            font-size: 5rem;
            color: #dc3545;
            margin-bottom: 1rem;
            line-height: 1;
        }
        .error-code {
            font-size: 3.5rem;
            font-weight: 700;
            color: #1e2a3a;
            line-height: 1;
            margin-bottom: 0.5rem;
        }
        .error-title {
            font-size: 1.25rem;
            font-weight: 600;
            color: #3c4858;
            margin-bottom: 0.75rem;
        }
        .error-desc {
            font-size: 0.9rem;
            color: #6c757d;
            margin-bottom: 2rem;
            line-height: 1.7;
        }
        .dev-panel {
            background: #f8f9fa;
            border: 1px solid #dee2e6;
            border-radius: 8px;
            padding: 1rem 1.25rem;
            text-align: left;
            margin-bottom: 1.5rem;
            font-size: 0.82rem;
        }
        .dev-panel .dev-label {
            font-weight: 600;
            color: #495057;
            margin-bottom: 0.25rem;
        }
        .dev-panel code {
            font-size: 0.8rem;
            word-break: break-all;
            color: #d63384;
        }
        .dev-panel .exception-detail {
            margin-top: 0.75rem;
            padding: 0.75rem;
            background: #fff5f5;
            border: 1px solid #f5c2c7;
            border-radius: 6px;
            color: #842029;
            white-space: pre-wrap;
            word-break: break-word;
            max-height: 200px;
            overflow-y: auto;
            font-family: 'SFMono-Regular', Consolas, monospace;
        }
    </style>
</head>
<body>
<div class="error-wrapper">
    <div class="error-card">
        <div class="error-icon"><i class="bi bi-exclamation-circle"></i></div>
        <div class="error-code">500</div>
        <div class="error-title">오류가 발생했습니다</div>
        <p class="error-desc">
            서버에서 요청을 처리하는 중 문제가 발생했습니다.<br />
            잠시 후 다시 시도하거나, 문제가 지속되면 관리자에게 문의하세요.
        </p>

        @if (Model.ShowDetails)
        {
            <div class="dev-panel">
                @if (!string.IsNullOrEmpty(Model.RequestId))
                {
                    <div class="dev-label">요청 ID</div>
                    <div class="mb-2"><code>@Model.RequestId</code></div>
                }
                @if (!string.IsNullOrEmpty(Model.ExceptionMessage))
                {
                    <div class="dev-label">오류 메시지</div>
                    <div class="exception-detail">@Model.ExceptionMessage</div>
                }
                @if (!string.IsNullOrEmpty(Model.ExceptionStackTrace))
                {
                    <div class="dev-label mt-2">스택 추적</div>
                    <div class="exception-detail" style="max-height:160px;">@Model.ExceptionStackTrace</div>
                }
            </div>
        }

        <div class="d-flex gap-2 justify-content-center flex-wrap">
            <button type="button" class="btn btn-outline-secondary" onclick="history.back()">
                <i class="bi bi-arrow-left me-1"></i> 이전 페이지
            </button>
            <a href="/" class="btn btn-primary" style="background-color:#0d6efd; border-color:#0d6efd;">
                <i class="bi bi-house me-1"></i> 홈으로 돌아가기
            </a>
        </div>
        <div class="mt-4" style="font-size:0.75rem; color:#adb5bd;">MSMES v1.0</div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-YvpcrYf0tY3lHB60NNkmXc4s9bIOgUxi8T/jzmUXCfAA3oGMlX2F8vaXIbAZLkJ" crossorigin="anonymous"></script>
</body>
</html>
