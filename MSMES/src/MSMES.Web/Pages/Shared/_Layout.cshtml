@{
    var title = ViewData["Title"] as string ?? "MSMES";
}
<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@title - MSMES</title>
    <style>
        * { box-sizing: border-box; }
        body { margin: 0; font-family: 'Segoe UI', sans-serif; background: #f4f6f9; }
        .layout { display: flex; min-height: 100vh; }
        .sidebar { width: 220px; background: #2c3e50; color: #ecf0f1; padding: 20px 0; }
        .sidebar h2 { padding: 0 20px; margin: 0 0 20px; font-size: 18px; }
        .sidebar a { display: block; color: #ecf0f1; padding: 10px 20px; text-decoration: none; }
        .sidebar a:hover, .sidebar a.active { background: #34495e; }
        .content { flex: 1; padding: 24px; }
        .topbar { background: #fff; padding: 12px 20px; border-bottom: 1px solid #ddd; display:flex; justify-content:space-between; }
        table { width: 100%; border-collapse: collapse; background: #fff; }
        th, td { padding: 8px 12px; border-bottom: 1px solid #eee; text-align: left; }
        th { background: #f0f2f5; }
        .btn { padding: 6px 14px; background: #3498db; color:#fff; border:none; border-radius:4px; cursor:pointer; text-decoration:none; }
    </style>
</head>
<body>
<div class="layout">
    <nav class="sidebar">
        <h2>MSMES</h2>
        <a href="/">대시보드</a>
        <a href="/SalesOrders">수주</a>
        <a href="/PurchaseOrders">발주</a>
        <a href="/WorkOrders">작업지시</a>
        <a href="/Lots">LOT 관리</a>
        <a href="/Shipments">출하</a>
    </nav>
    <main class="content">
        <div class="topbar">
            <strong>@title</strong>
            <span>@User.Identity?.Name</span>
        </div>
        <div style="padding-top: 20px;">
            @RenderBody()
        </div>
    </main>
</div>
</body>
</html>
