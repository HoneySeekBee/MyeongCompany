@page
@model MSMES.Web.Pages.WorkOrders.IndexModel
@{
    ViewData["Title"] = "작업지시";
}

<!-- 페이지 헤더 -->
<div class="ms-page-header">
    <div class="ms-page-header__left">
        <h1><i class="bi bi-gear me-2 text-primary-ms"></i>작업지시</h1>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/">홈</a></li>
                <li class="breadcrumb-item active" aria-current="page">작업지시</li>
            </ol>
        </nav>
    </div>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalWorkOrder"
            onclick="openCreateWoModal()" aria-label="작업지시 등록">
        <i class="bi bi-plus-lg me-1"></i>작업지시 등록
    </button>
</div>

<!-- 검색 필터 카드 -->
<div class="ms-filter-card">
    <form id="woSearchForm" method="get" class="row g-2 align-items-end">
        <div class="col-12 col-sm-6 col-md-3">
            <label for="woFilterNo" class="form-label text-muted-sm mb-1">작업지시번호</label>
            <input type="text" id="woFilterNo" name="woNo" class="form-control form-control-sm"
                   placeholder="WO-2026-..." value="@Request.Query["woNo"]" />
        </div>
        <div class="col-12 col-sm-6 col-md-3">
            <label for="woFilterItem" class="form-label text-muted-sm mb-1">품목명</label>
            <input type="text" id="woFilterItem" name="item" class="form-control form-control-sm"
                   placeholder="품목명 검색" value="@Request.Query["item"]" />
        </div>
        <div class="col-12 col-sm-6 col-md-2">
            <label for="woFilterStatus" class="form-label text-muted-sm mb-1">상태</label>
            <select id="woFilterStatus" name="status" class="form-select form-select-sm">
                <option value="">전체</option>
                @{ var selWoStatus = Request.Query["status"].ToString(); }
                <option value="Planned"    selected="@(selWoStatus == "Planned"    ? "selected" : null)">계획</option>
                <option value="InProgress" selected="@(selWoStatus == "InProgress" ? "selected" : null)">진행중</option>
                <option value="Completed"  selected="@(selWoStatus == "Completed"  ? "selected" : null)">완료</option>
                <option value="Cancelled"  selected="@(selWoStatus == "Cancelled"  ? "selected" : null)">취소</option>
            </select>
        </div>
        <div class="col-12 col-sm-6 col-md-auto d-flex gap-2">
            <button type="submit" class="btn btn-sm btn-primary" aria-label="검색">
                <i class="bi bi-search me-1"></i>검색
            </button>
            <a href="/WorkOrders" class="btn btn-sm btn-outline-secondary" aria-label="초기화">
                <i class="bi bi-arrow-counterclockwise me-1"></i>초기화
            </a>
        </div>
    </form>
</div>

