<!-- ════════════════════════════════════════════
     작업지시 등록/수정 모달
════════════════════════════════════════════ -->
<div class="modal fade" id="modalWorkOrder" tabindex="-1"
     aria-labelledby="modalWorkOrderLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalWorkOrderLabel">
                    <i class="bi bi-gear me-2"></i>
                    <span id="modalWorkOrderTitle">작업지시 등록</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="닫기"></button>
            </div>
            <form id="formWorkOrder" class="needs-validation" novalidate>
                <div class="modal-body">
                    <input type="hidden" id="woId" name="id" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label for="woOrderNo" class="form-label">
                                작업지시번호 <span class="text-danger">*</span>
                            </label>
                            <input type="text" id="woOrderNo" name="workOrderNo"
                                   class="form-control" placeholder="WO-2026-XXXX" required />
                            <div class="invalid-feedback">작업지시번호는 필수 입력입니다.</div>
                        </div>
                        <div class="col-md-6">
                            <label for="woSalesRef" class="form-label">수주참조번호</label>
                            <input type="text" id="woSalesRef" name="salesOrderNo"
                                   class="form-control" placeholder="SO-2026-XXXX" />
                        </div>
                        <div class="col-md-6">
                            <label for="woItemCode" class="form-label">
                                품목코드 <span class="text-danger">*</span>
                            </label>
                            <input type="text" id="woItemCode" name="itemCode"
                                   class="form-control" placeholder="ITEM-001" required />
                            <div class="invalid-feedback">품목코드는 필수 입력입니다.</div>
                        </div>
                        <div class="col-md-6">
                            <label for="woItemName" class="form-label">품목명</label>
                            <input type="text" id="woItemName" name="itemName"
                                   class="form-control" placeholder="품목명" />
                        </div>
                        <div class="col-md-4">
                            <label for="woQty" class="form-label">
                                계획수량 <span class="text-danger">*</span>
                            </label>
                            <input type="number" id="woQty" name="plannedQty"
                                   class="form-control" placeholder="0" min="1" required />
                            <div class="invalid-feedback">계획수량은 1 이상이어야 합니다.</div>
                        </div>
                        <div class="col-md-4">
                            <label for="woStartDate" class="form-label">
                                시작일 <span class="text-danger">*</span>
                            </label>
                            <input type="date" id="woStartDate" name="startDate"
                                   class="form-control" required />
                            <div class="invalid-feedback">시작일은 필수 입력입니다.</div>
                        </div>
                        <div class="col-md-4">
                            <label for="woEndDate" class="form-label">완료예정일</label>
                            <input type="date" id="woEndDate" name="endDate"
                                   class="form-control" />
                        </div>
                        <div class="col-md-4">
                            <label for="woStatus2" class="form-label">상태</label>
                            <select id="woStatus2" name="status" class="form-select">
                                <option value="Planned">계획</option>
                                <option value="InProgress">진행중</option>
                                <option value="Completed">완료</option>
                                <option value="Cancelled">취소</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="woProgress" class="form-label">진행률 (%)</label>
                            <div class="input-group">
                                <input type="number" id="woProgress" name="progressRate"
                                       class="form-control" placeholder="0" min="0" max="100" value="0" />
                                <span class="input-group-text">%</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <label for="woNote" class="form-label">비고</label>
                            <textarea id="woNote" name="note" class="form-control" rows="2"
                                      placeholder="특이사항을 입력하세요"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        취소
                    </button>
                    <button type="submit" class="btn btn-primary" data-save aria-label="저장">
                        <i class="bi bi-check-lg me-1"></i>저장
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    function openCreateWoModal() {
        document.getElementById('modalWorkOrderTitle').textContent = '작업지시 등록';
        document.getElementById('formWorkOrder').reset();
        document.getElementById('formWorkOrder').classList.remove('was-validated');
        document.getElementById('woProgress').value = '0';
        var today = new Date().toISOString().slice(0, 10);
        document.getElementById('woStartDate').value = today;
    }

    function openWoEditModal(woNo) {
        document.getElementById('modalWorkOrderTitle').textContent = '작업지시 수정';
        document.getElementById('formWorkOrder').classList.remove('was-validated');
        document.getElementById('woOrderNo').value = woNo;
        var modal = new bootstrap.Modal(document.getElementById('modalWorkOrder'));
        modal.show();
    }

    function openWoDetailModal(woNo) {
        openWoEditModal(woNo);
    }

    function confirmDeleteWo(woNo) {
        if (confirm('"' + woNo + '" 작업지시를 삭제하시겠습니까?')) {
            msFetch('/api/workorders/' + woNo, { method: 'DELETE' })
                .then(function(res) {
                    if (res.ok) {
                        showToast('작업지시가 삭제되었습니다.', 'success');
                        setTimeout(function() { location.reload(); }, 1000);
                    } else {
                        showToast('삭제 실패: 서버 오류', 'danger');
                    }
                })
                .catch(function() {
                    showToast('삭제 실패: 네트워크 오류', 'danger');
                });
        }
    }

    document.getElementById('formWorkOrder').addEventListener('submit', function(e) {
        e.preventDefault();
        e.stopPropagation();
        if (!this.checkValidity()) {
            this.classList.add('was-validated');
            var firstInvalid = this.querySelector(':invalid');
            if (firstInvalid) firstInvalid.focus();
            return;
        }
        var data = Object.fromEntries(new FormData(this).entries());
        var isEdit = !!data.id;
        var url    = isEdit ? '/api/workorders/' + data.id : '/api/workorders';
        var method = isEdit ? 'PUT' : 'POST';

        msFetch(url, { method: method, body: JSON.stringify(data) })
            .then(function(res) {
                if (res.ok) {
                    bootstrap.Modal.getInstance(document.getElementById('modalWorkOrder')).hide();
                    showToast('작업지시가 ' + (isEdit ? '수정' : '등록') + '되었습니다.', 'success');
                    setTimeout(function() { location.reload(); }, 1200);
                } else {
                    return res.json().then(function(err) {
                        showToast('저장 실패: ' + (err.message || '알 수 없는 오류'), 'danger');
                    });
                }
            })
            .catch(function() {
                showToast('저장 실패: 네트워크 오류', 'danger');
            });
    });
</script>
}
