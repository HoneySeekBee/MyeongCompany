@page "{no}"
@model MSMES.Web.Pages.PurchaseOrders.PrintModel
@{
    Layout = "_PrintLayout";
    var po = Model.PurchaseOrder!;
    var printedAt = DateTime.Now.ToString("yyyy-MM-dd HH:mm");
}

<!-- 인쇄/닫기 버튼 -->
<div class="no-print">
    <button type="button" class="btn btn-primary btn-sm" onclick="window.print()">
        <i class="bi bi-printer me-1"></i>인쇄
    </button>
    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="window.close()">
        닫기
    </button>
</div>

<!-- 문서 헤더 -->
<div class="print-header d-flex justify-content-between align-items-end">
    <div>
        <div class="company-name">MSMES</div>
        <div class="company-sub">Manufacturing Execution System</div>
    </div>
    <div class="doc-title">발&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;주&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;서</div>
    <div style="width:160px;"></div>
</div>

<!-- 기본 정보 -->
<table class="info-table">
    <tr>
        <td class="label">수신</td>
        <td colspan="3">@po.SupplierName</td>
    </tr>
    <tr>
        <td class="label">발주번호</td>
        <td>@po.PurchaseOrderNo</td>
        <td class="label">공급업체코드</td>
        <td>@po.SupplierCode</td>
    </tr>
    <tr>
        <td class="label">발주일</td>
        <td>@po.OrderDate.ToString("yyyy-MM-dd")</td>
        <td class="label">납기일</td>
        <td>@po.DueDate.ToString("yyyy-MM-dd")</td>
    </tr>
    <tr>
        <td class="label">담당자</td>
        <td>@(po.AssignedTo ?? "—")</td>
        <td class="label">상태</td>
        <td>@po.Status.ToString()</td>
    </tr>
    <tr>
        <td class="label">비고</td>
        <td colspan="3">@(po.Note ?? "—")</td>
    </tr>
</table>

<!-- 발주 품목 -->
<div style="font-weight:700; margin-bottom:8px;">발주 품목</div>
<table class="items-table">
    <thead>
        <tr>
            <th style="width:40px;">No</th>
            <th>품목코드</th>
            <th class="text-left">품목명</th>
            <th>수량</th>
            <th class="text-right">단가</th>
            <th class="text-right">금액</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in po.Items)
        {
            <tr>
                <td>@item.ItemNo</td>
                <td>@item.ItemCode</td>
                <td class="text-left">@item.ItemName</td>
                <td>@item.OrderQuantity.ToString("N0")</td>
                <td class="text-right">@(item.UnitPrice.ToString("N0"))원</td>
                <td class="text-right">@(item.Amount.ToString("N0"))원</td>
            </tr>
        }
        <tr class="total-row">
            <td colspan="5" style="text-align:right; font-weight:700;">합&nbsp;&nbsp;&nbsp;&nbsp;계</td>
            <td class="text-right">@(po.TotalAmount.ToString("N0"))원</td>
        </tr>
    </tbody>
</table>

<!-- 서명란 -->
<div class="sign-area">
    <div class="sign-box">
        <div class="sign-label">작성</div>
        <div class="sign-space"></div>
    </div>
    <div class="sign-box">
        <div class="sign-label">검토</div>
        <div class="sign-space"></div>
    </div>
    <div class="sign-box">
        <div class="sign-label">승인</div>
        <div class="sign-space"></div>
    </div>
    <div class="sign-box">
        <div class="sign-label">공급업체확인</div>
        <div class="sign-space"></div>
    </div>
</div>

<!-- 출력 일시 -->
<div class="print-footer">
    출력일시: @printedAt
</div>

@section Scripts {
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
}
