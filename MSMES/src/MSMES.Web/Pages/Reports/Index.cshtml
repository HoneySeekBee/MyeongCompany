@page
@model MSMES.Web.Pages.Reports.IndexModel
@{ ViewData["Title"] = "통합 보고서"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">통합 보고서</h1>
    <button class="btn btn-outline-secondary btn-sm" onclick="window.print()">
        <i class="bi bi-printer me-1"></i>인쇄
    </button>
</div>

<!-- Period selector -->
<div class="card border-0 shadow-sm mb-4 no-print">
    <div class="card-body py-3">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-end">
            <div>
                <label class="form-label small mb-1">기간 프리셋</label>
                <div class="btn-group">
                    <a href="?Period=daily"   class="btn btn-sm @(Model.Period=="daily"  ?"btn-primary":"btn-outline-primary")">오늘</a>
                    <a href="?Period=weekly"  class="btn btn-sm @(Model.Period=="weekly" ?"btn-primary":"btn-outline-primary")">최근 7일</a>
                    <a href="?Period=monthly" class="btn btn-sm @(Model.Period=="monthly"?"btn-primary":"btn-outline-primary")">이번 달</a>
                </div>
            </div>
            <div>
                <label class="form-label small mb-1">직접 입력</label>
                <div class="d-flex gap-1 align-items-center">
                    <input type="hidden" name="Period" value="custom" />
                    <input type="date" name="DateFrom" class="form-control form-control-sm"
                           value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
                    <span class="text-muted">~</span>
                    <input type="date" name="DateTo" class="form-control form-control-sm"
                           value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
                    <button type="submit" class="btn btn-primary btn-sm">조회</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Report header (print only) -->
<div class="text-center mb-4 print-only" style="display:none;">
    <h2>MSMES 생산 보고서</h2>
    <p class="text-muted">@Model.ReportFrom.ToString("yyyy년 MM월 dd일") ~ @Model.ReportTo.ToString("yyyy년 MM월 dd일")</p>
    <p class="text-muted small">출력일시: @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</p>
</div>

<!-- KPI Summary -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <i class="bi bi-boxes fs-3 text-primary mb-1"></i>
            <div class="text-muted small">총 생산량</div>
            <div class="h3 fw-bold mb-0">@Model.TotalProduced.ToString("N0")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <i class="bi bi-exclamation-triangle fs-3 text-danger mb-1"></i>
            <div class="text-muted small">불량률</div>
            <div class="h3 fw-bold mb-0 @(Model.DefectRate > 5 ? "text-danger" : Model.DefectRate > 2 ? "text-warning" : "text-success")">
                @Model.DefectRate%
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <i class="bi bi-patch-check fs-3 text-success mb-1"></i>
            <div class="text-muted small">품질 합격률</div>
            <div class="h3 fw-bold mb-0 text-success">@Model.PassRate%</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <i class="bi bi-truck fs-3 text-info mb-1"></i>
            <div class="text-muted small">출하 건수</div>
            <div class="h3 fw-bold mb-0">@Model.ShipmentTotal</div>
        </div>
    </div>
</div>

<!-- Production chart + Quality doughnut -->
<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h6 class="mb-0">일별 생산 추이</h6>
            </div>
            <div class="card-body">
                <canvas id="productionChart" height="80"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h6 class="mb-0">품질 검사 결과</h6>
            </div>
            <div class="card-body d-flex flex-column justify-content-center">
                @if (Model.QualityInspected > 0)
                {
                    <canvas id="qualityChart" height="140"></canvas>
                }
                else
                {
                    <div class="text-center text-muted py-3">검사 데이터 없음</div>
                }
                <div class="mt-3 text-center">
                    <span class="text-success me-3"><i class="bi bi-check-circle"></i> 합격 @Model.QualityPassed</span>
                    <span class="text-danger"><i class="bi bi-x-circle"></i> 불합격 @Model.QualityFailed</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Shipment summary row -->
<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h6 class="mb-0">출하 현황</h6>
            </div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col-6 col-md-3">
                        <div class="text-muted small">총 출하 건수</div>
                        <div class="h4 fw-bold">@Model.ShipmentTotal</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="text-muted small">배송 완료</div>
                        <div class="h4 fw-bold text-success">@Model.ShipmentDelivered</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="text-muted small">배송 중</div>
                        <div class="h4 fw-bold text-info">@(Model.ShipmentTotal - Model.ShipmentDelivered)</div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="text-muted small">배송 완료율</div>
                        <div class="h4 fw-bold @(Model.ShipmentTotal == 0 ? "" : Model.ShipmentDelivered == Model.ShipmentTotal ? "text-success" : "text-warning")">
                            @(Model.ShipmentTotal == 0 ? "0" : Math.Round((decimal)Model.ShipmentDelivered / Model.ShipmentTotal * 100, 1).ToString())%
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Detailed daily table -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-0 pt-4 pb-0">
        <h6 class="mb-0">일별 생산 상세</h6>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>날짜</th>
                    <th>생산량</th>
                    <th>불량량</th>
                    <th>불량률</th>
                    <th>양품률</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var (label, produced, defect) in Model.ProductionTrend)
            {
                var rate   = produced == 0 ? 0m : Math.Round(defect / produced * 100, 1);
                var good   = produced == 0 ? 0m : Math.Round((produced - defect) / produced * 100, 1);
                <tr>
                    <td>@label</td>
                    <td>@produced.ToString("N0")</td>
                    <td>@defect.ToString("N0")</td>
                    <td class="@(rate > 5 ? "text-danger fw-semibold" : rate > 2 ? "text-warning fw-semibold" : "text-success")">@rate%</td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="progress flex-grow-1" style="height:6px; max-width:80px;">
                                <div class="progress-bar bg-primary" style="width:@good%"></div>
                            </div>
                            <span class="small text-muted">@good%</span>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.ProductionTrend.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-4">데이터가 없습니다.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>

<!-- Print styles -->
<style>
@@media print {
    .no-print { display: none !important; }
    .print-only { display: block !important; }
    .ms-sidebar, nav { display: none !important; }
    .ms-main { margin: 0 !important; }
    .card { box-shadow: none !important; border: 1px solid #ddd !important; }
}
</style>

@section Scripts {
<script>
(function () {
    var trend = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.ProductionTrend.Select(t => new { label = t.Label, produced = t.Produced, defect = t.Defect })
    ));

    if (trend.length > 0) {
        new Chart(document.getElementById('productionChart'), {
            type: 'bar',
            data: {
                labels: trend.map(function(t) { return t.label; }),
                datasets: [
                    {
                        label: '생산량',
                        data: trend.map(function(t) { return t.produced; }),
                        backgroundColor: 'rgba(52,152,219,0.7)'
                    },
                    {
                        label: '불량량',
                        data: trend.map(function(t) { return t.defect; }),
                        backgroundColor: 'rgba(231,76,60,0.6)'
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom' } },
                scales: { y: { beginAtZero: true } }
            }
        });
    }

@if (Model.QualityInspected > 0)
{
    <text>
    new Chart(document.getElementById('qualityChart'), {
        type: 'doughnut',
        data: {
            labels: ['합격', '불합격'],
            datasets: [{
                data: [@Model.QualityPassed, @Model.QualityFailed],
                backgroundColor: ['#27ae60', '#e74c3c']
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } }
        }
    });
    </text>
}
})();
</script>
}
