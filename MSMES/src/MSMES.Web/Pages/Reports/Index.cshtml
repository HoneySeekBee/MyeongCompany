@page
@model MSMES.Web.Pages.Reports.IndexModel
@{ ViewData["Title"] = "통합 보고서"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0"><i class="bi bi-bar-chart-line me-2 text-primary"></i>통합 보고서</h1>
    <div class="d-flex gap-2 no-print">
        <button class="btn btn-outline-success btn-sm" onclick="exportExcel()">
            <i class="bi bi-file-earmark-excel me-1"></i>Excel 내보내기
        </button>
        <button class="btn btn-outline-danger btn-sm" onclick="exportPdf()">
            <i class="bi bi-file-earmark-pdf me-1"></i>PDF 출력
        </button>
        <button class="btn btn-outline-secondary btn-sm" onclick="window.print()">
            <i class="bi bi-printer me-1"></i>인쇄
        </button>
    </div>
</div>

<!-- Period selector -->
<div class="card border-0 shadow-sm mb-4 no-print">
    <div class="card-body py-3">
        <form method="get" class="d-flex flex-wrap gap-2 align-items-end">
            <div>
                <label class="form-label small mb-1">기간 프리셋</label>
                <div class="btn-group">
                    <a href="?Period=daily"   class="btn btn-sm @(Model.Period=="daily"  ?"btn-primary":"btn-outline-primary")">오늘</a>
                    <a href="?Period=weekly"  class="btn btn-sm @(Model.Period=="weekly" ?"btn-primary":"btn-outline-primary")">최근 7일</a>
                    <a href="?Period=monthly" class="btn btn-sm @(Model.Period=="monthly"?"btn-primary":"btn-outline-primary")">이번 달</a>
                </div>
            </div>
            <div>
                <label class="form-label small mb-1">직접 입력</label>
                <div class="d-flex gap-1 align-items-center">
                    <input type="hidden" name="Period" value="custom" />
                    <input type="date" name="DateFrom" class="form-control form-control-sm"
                           value="@Model.DateFrom?.ToString("yyyy-MM-dd")" />
                    <span class="text-muted">~</span>
                    <input type="date" name="DateTo" class="form-control form-control-sm"
                           value="@Model.DateTo?.ToString("yyyy-MM-dd")" />
                    <button type="submit" class="btn btn-primary btn-sm">
                        <i class="bi bi-search me-1"></i>조회
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Report header (print only) -->
<div class="text-center mb-4 print-only" style="display:none;">
    <h2>MSMES 생산 보고서</h2>
    <p class="text-muted">@Model.ReportFrom.ToString("yyyy년 MM월 dd일") ~ @Model.ReportTo.ToString("yyyy년 MM월 dd일")</p>
    <p class="text-muted small">출력일시: @DateTime.Now.ToString("yyyy-MM-dd HH:mm")</p>
</div>

<!-- KPI Summary -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <i class="bi bi-boxes fs-3 text-primary mb-1"></i>
            <div class="text-muted small">총 생산량</div>
            <div class="h3 fw-bold mb-0">@Model.TotalProduced.ToString("N0")</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <i class="bi bi-exclamation-triangle fs-3 text-danger mb-1"></i>
            <div class="text-muted small">불량률</div>
            <div class="h3 fw-bold mb-0 @(Model.DefectRate > 5 ? "text-danger" : Model.DefectRate > 2 ? "text-warning" : "text-success")">
                @Model.DefectRate%
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <i class="bi bi-check2-circle fs-3 text-success mb-1"></i>
            <div class="text-muted small">작업지시 완료율</div>
            <div class="h3 fw-bold mb-0 text-success" id="woCompletionKpi">— %</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <i class="bi bi-truck fs-3 text-info mb-1"></i>
            <div class="text-muted small">출하 건수</div>
            <div class="h3 fw-bold mb-0">@Model.ShipmentTotal</div>
        </div>
    </div>
</div>

<!-- ── Row 1: 월별 생산 실적 + 수주 현황 도넛 ── -->
<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-bar-chart me-1 text-primary"></i>월별 생산 실적 (최근 6개월)</h6>
                <span class="badge bg-secondary-subtle text-secondary small">계획 대비 실적</span>
            </div>
            <div class="card-body">
                <canvas id="monthlyProductionChart" height="90"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h6 class="mb-0"><i class="bi bi-pie-chart me-1 text-warning"></i>수주 상태 현황</h6>
            </div>
            <div class="card-body d-flex flex-column justify-content-center">
                <canvas id="salesOrderStatusChart" height="160"></canvas>
                <div class="mt-3 d-flex flex-wrap justify-content-center gap-2" id="soLegend"></div>
            </div>
        </div>
    </div>
</div>

<!-- ── Row 2: 재고 수준 막대 + 기존 품질 도넛 ── -->
<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-boxes me-1 text-info"></i>재고 수준 현황 (상위 10개 품목)</h6>
                <small class="text-muted"><span class="badge bg-danger-subtle text-danger">빨강</span> 안전재고 미달 &nbsp;
                    <span class="badge bg-warning-subtle text-warning">노랑</span> 안전재고 근접</small>
            </div>
            <div class="card-body">
                <canvas id="inventoryStockChart" height="100"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h6 class="mb-0"><i class="bi bi-patch-check me-1 text-success"></i>품질 검사 결과</h6>
            </div>
            <div class="card-body d-flex flex-column justify-content-center">
                @if (Model.QualityInspected > 0)
                {
                    <canvas id="qualityChart" height="140"></canvas>
                }
                else
                {
                    <div class="text-center text-muted py-3">
                        <i class="bi bi-clipboard-x fs-2 d-block mb-2"></i>검사 데이터 없음
                    </div>
                }
                <div class="mt-3 text-center">
                    <span class="text-success me-3"><i class="bi bi-check-circle"></i> 합격 @Model.QualityPassed</span>
                    <span class="text-danger"><i class="bi bi-x-circle"></i> 불합격 @Model.QualityFailed</span>
                </div>
                <div class="text-center mt-2">
                    <span class="badge bg-success-subtle text-success fs-6">합격률 @Model.PassRate%</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ── Row 3: 기존 일별 생산 차트 ── -->
<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h6 class="mb-0"><i class="bi bi-graph-up me-1 text-primary"></i>일별 생산 추이</h6>
            </div>
            <div class="card-body">
                <canvas id="productionChart" height="90"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-white border-0 pt-4 pb-0">
                <h6 class="mb-0"><i class="bi bi-truck me-1 text-info"></i>출하 현황</h6>
            </div>
            <div class="card-body d-flex flex-column justify-content-center">
                <div class="row text-center g-3">
                    <div class="col-6">
                        <div class="text-muted small">총 출하 건수</div>
                        <div class="h4 fw-bold">@Model.ShipmentTotal</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small">배송 완료</div>
                        <div class="h4 fw-bold text-success">@Model.ShipmentDelivered</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small">배송 중</div>
                        <div class="h4 fw-bold text-info">@(Model.ShipmentTotal - Model.ShipmentDelivered)</div>
                    </div>
                    <div class="col-6">
                        <div class="text-muted small">배송 완료율</div>
                        <div class="h4 fw-bold @(Model.ShipmentTotal == 0 ? "" : Model.ShipmentDelivered == Model.ShipmentTotal ? "text-success" : "text-warning")">
                            @(Model.ShipmentTotal == 0 ? "0" : Math.Round((decimal)Model.ShipmentDelivered / Model.ShipmentTotal * 100, 1).ToString())%
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Summary metrics table -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-0 pt-4 pb-0 d-flex justify-content-between align-items-center">
        <h6 class="mb-0"><i class="bi bi-table me-1"></i>핵심 지표 요약</h6>
        <small class="text-muted no-print">조회 기간: @Model.ReportFrom.ToString("yyyy-MM-dd") ~ @Model.ReportTo.ToString("yyyy-MM-dd")</small>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0" id="summaryTable">
            <thead class="table-dark">
                <tr>
                    <th>구분</th>
                    <th class="text-end">값</th>
                    <th>비고</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td><i class="bi bi-boxes text-primary me-1"></i>총 생산량</td>
                    <td class="text-end fw-semibold">@Model.TotalProduced.ToString("N0") EA</td>
                    <td class="text-muted small">조회 기간 내 누계</td>
                </tr>
                <tr>
                    <td><i class="bi bi-exclamation-triangle text-danger me-1"></i>불량량</td>
                    <td class="text-end fw-semibold @(Model.DefectRate > 5 ? "text-danger" : "")">@Model.TotalDefect.ToString("N0") EA</td>
                    <td class="text-muted small">불량률 @Model.DefectRate%</td>
                </tr>
                <tr>
                    <td><i class="bi bi-patch-check text-success me-1"></i>품질 합격</td>
                    <td class="text-end fw-semibold text-success">@Model.QualityPassed 건</td>
                    <td class="text-muted small">합격률 @Model.PassRate%</td>
                </tr>
                <tr>
                    <td><i class="bi bi-x-circle text-danger me-1"></i>품질 불합격</td>
                    <td class="text-end fw-semibold text-danger">@Model.QualityFailed 건</td>
                    <td class="text-muted small">총 검사 @Model.QualityInspected 건</td>
                </tr>
                <tr>
                    <td><i class="bi bi-truck text-info me-1"></i>총 출하</td>
                    <td class="text-end fw-semibold">@Model.ShipmentTotal 건</td>
                    <td class="text-muted small">배송 완료 @Model.ShipmentDelivered 건</td>
                </tr>
                <tr>
                    <td><i class="bi bi-exclamation-diamond text-warning me-1"></i>안전재고 미달 품목</td>
                    <td class="text-end fw-semibold text-warning" id="lowStockCount">— 건</td>
                    <td class="text-muted small">즉시 발주 검토 필요</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Detailed daily table -->
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-white border-0 pt-4 pb-0">
        <h6 class="mb-0"><i class="bi bi-calendar3 me-1"></i>일별 생산 상세</h6>
    </div>
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>날짜</th>
                    <th class="text-end">생산량</th>
                    <th class="text-end">불량량</th>
                    <th class="text-end">불량률</th>
                    <th>양품률</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var (label, produced, defect) in Model.ProductionTrend)
            {
                var rate = produced == 0 ? 0m : Math.Round(defect / produced * 100, 1);
                var good = produced == 0 ? 0m : Math.Round((produced - defect) / produced * 100, 1);
                <tr>
                    <td>@label</td>
                    <td class="text-end">@produced.ToString("N0")</td>
                    <td class="text-end">@defect.ToString("N0")</td>
                    <td class="text-end @(rate > 5 ? "text-danger fw-semibold" : rate > 2 ? "text-warning fw-semibold" : "text-success")">@rate%</td>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            <div class="progress flex-grow-1" style="height:6px; max-width:80px;">
                                <div class="progress-bar bg-primary" style="width:@good%"></div>
                            </div>
                            <span class="small text-muted">@good%</span>
                        </div>
                    </td>
                </tr>
            }
            @if (!Model.ProductionTrend.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-4">데이터가 없습니다.</td></tr>
            }
            </tbody>
        </table>
    </div>
</div>

<!-- Toast for export placeholder -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:1100;">
    <div id="exportToast" class="toast align-items-center text-bg-secondary border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                <i class="bi bi-info-circle me-2"></i><span id="exportToastMsg">준비 중입니다.</span>
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="닫기"></button>
        </div>
    </div>
</div>

<!-- Print styles -->
<style>
@@media print {
    .no-print { display: none !important; }
    .print-only { display: block !important; }
    .ms-sidebar, nav { display: none !important; }
    .ms-main { margin: 0 !important; }
    .card { box-shadow: none !important; border: 1px solid #ddd !important; }
}
</style>

@section Scripts {
<script>
(function () {
    /* ── 공통 유틸 ───────────────────────────────────────────── */
    function showToast(msg) {
        document.getElementById('exportToastMsg').textContent = msg;
        var el = document.getElementById('exportToast');
        bootstrap.Toast.getOrCreateInstance(el, { delay: 3000 }).show();
    }

    window.exportExcel = function () { showToast('Excel 내보내기 기능은 준비 중입니다.'); };
    window.exportPdf   = function () { showToast('PDF 출력 기능은 준비 중입니다.'); };

    /* ── 1. 일별 생산 추이 (기존 데이터 사용) ─────────────────── */
    var trend = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.ProductionTrend.Select(t => new { label = t.Label, produced = t.Produced, defect = t.Defect })
    ));

    if (trend.length > 0) {
        new Chart(document.getElementById('productionChart'), {
            type: 'bar',
            data: {
                labels: trend.map(function(t) { return t.label; }),
                datasets: [
                    { label: '생산량', data: trend.map(function(t) { return t.produced; }), backgroundColor: 'rgba(52,152,219,0.75)', borderRadius: 4 },
                    { label: '불량량', data: trend.map(function(t) { return t.defect; }),   backgroundColor: 'rgba(231,76,60,0.65)',  borderRadius: 4 }
                ]
            },
            options: {
                responsive: true,
                plugins: { legend: { position: 'bottom' } },
                scales: { y: { beginAtZero: true } }
            }
        });
    }

    /* ── 2. 품질 검사 도넛 (기존) ──────────────────────────────── */
@if (Model.QualityInspected > 0)
{
    <text>
    new Chart(document.getElementById('qualityChart'), {
        type: 'doughnut',
        data: {
            labels: ['합격', '불합격'],
            datasets: [{ data: [@Model.QualityPassed, @Model.QualityFailed], backgroundColor: ['#27ae60', '#e74c3c'], borderWidth: 0 }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: function(ctx) {
                            var total = ctx.dataset.data.reduce(function(a, b) { return a + b; }, 0);
                            var pct = total > 0 ? Math.round(ctx.parsed / total * 100) : 0;
                            return ctx.label + ': ' + ctx.parsed + '건 (' + pct + '%)';
                        }
                    }
                }
            }
        }
    });
    </text>
}

    /* ── 3. 월별 생산 실적 (최근 6개월 데모 데이터) ───────────── */
    (function () {
        var now = new Date();
        var months = [];
        for (var i = 5; i >= 0; i--) {
            var d = new Date(now.getFullYear(), now.getMonth() - i, 1);
            months.push((d.getMonth() + 1) + '월');
        }
        // 계획 vs 실적 (데모 — 실 API 연동 전 하드코딩)
        var planned  = [2800, 3100, 2950, 3300, 3500, 3200];
        var produced = [2650, 2980, 2740, 3290, 3480, 2900];

        // 작업지시 완료율 KPI (실적/계획 최신 달 기준)
        var lastPlan = planned[planned.length - 1];
        var lastProd = produced[produced.length - 1];
        var completionPct = lastPlan > 0 ? Math.round(lastProd / lastPlan * 100) : 0;
        document.getElementById('woCompletionKpi').textContent = completionPct + '%';
        document.getElementById('woCompletionKpi').className =
            'h3 fw-bold mb-0 ' + (completionPct >= 95 ? 'text-success' : completionPct >= 80 ? 'text-warning' : 'text-danger');

        new Chart(document.getElementById('monthlyProductionChart'), {
            type: 'bar',
            data: {
                labels: months,
                datasets: [
                    {
                        label: '계획량',
                        data: planned,
                        backgroundColor: 'rgba(149,165,166,0.55)',
                        borderColor: 'rgba(149,165,166,0.9)',
                        borderWidth: 1,
                        borderRadius: 4,
                        order: 2
                    },
                    {
                        label: '실적량',
                        data: produced,
                        backgroundColor: function(ctx) {
                            var i = ctx.dataIndex;
                            return produced[i] >= planned[i] ? 'rgba(39,174,96,0.75)' : 'rgba(52,152,219,0.75)';
                        },
                        borderRadius: 4,
                        order: 1
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' },
                    tooltip: {
                        callbacks: {
                            afterBody: function(items) {
                                var i   = items[0].dataIndex;
                                var pct = planned[i] > 0 ? Math.round(produced[i] / planned[i] * 100) : 0;
                                return ['달성률: ' + pct + '%'];
                            }
                        }
                    }
                },
                scales: { y: { beginAtZero: true, ticks: { callback: function(v) { return v.toLocaleString(); } } } }
            }
        });
    })();

    /* ── 4. 수주 상태 도넛 (데모 데이터) ──────────────────────── */
    (function () {
        var soLabels = ['초안', '확정', '생산중', '출하', '마감'];
        var soData   = [1, 2, 3, 1, 1];   // SO-2026-0001~0005 기준
        var soColors = ['#95a5a6', '#3498db', '#f39c12', '#27ae60', '#8e44ad'];

        new Chart(document.getElementById('salesOrderStatusChart'), {
            type: 'doughnut',
            data: {
                labels: soLabels,
                datasets: [{
                    data: soData,
                    backgroundColor: soColors,
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            },
            options: {
                responsive: true,
                cutout: '62%',
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(ctx) {
                                var total = ctx.dataset.data.reduce(function(a, b) { return a + b; }, 0);
                                var pct = total > 0 ? Math.round(ctx.parsed / total * 100) : 0;
                                return ctx.label + ': ' + ctx.parsed + '건 (' + pct + '%)';
                            }
                        }
                    }
                }
            }
        });

        // 범례 직접 생성
        var legend = document.getElementById('soLegend');
        soLabels.forEach(function(label, i) {
            var span = document.createElement('span');
            span.className = 'badge';
            span.style.backgroundColor = soColors[i];
            span.style.fontSize = '0.72rem';
            span.style.padding = '4px 8px';
            span.textContent = label + ' ' + soData[i] + '건';
            legend.appendChild(span);
        });
    })();

    /* ── 5. 재고 수준 막대 차트 (데모 데이터 — 상위 10 품목) ─── */
    (function () {
        var items = [
            { name: '엔진 브래킷',   current: 45,  safety: 20  },
            { name: '볼트 M12x40',  current: 8,   safety: 50  },
            { name: '하우징 B형',    current: 3,   safety: 10  },
            { name: '샤프트 조립품', current: 22,  safety: 15  },
            { name: '너트 M8',       current: 156, safety: 100 },
            { name: 'PCB 기판 A형',  current: 12,  safety: 20  },
            { name: '알루미늄 프레임', current: 34, safety: 10  },
            { name: 'USB 케이블',    current: 67,  safety: 30  },
            { name: '압축 스프링',   current: 200, safety: 50  },
            { name: '기어 모듈 M3',  current: 5,   safety: 15  }
        ];

        var lowStockCount = items.filter(function(it) { return it.current < it.safety; }).length;
        document.getElementById('lowStockCount').textContent = lowStockCount + '건';
        document.getElementById('lowStockCount').className = 'text-end fw-semibold ' + (lowStockCount > 0 ? 'text-danger' : 'text-success');

        var bgColors = items.map(function(it) {
            if (it.current <= it.safety * 0.5) return 'rgba(231,76,60,0.80)';   // 위험: 빨강
            if (it.current < it.safety)         return 'rgba(230,126,34,0.80)'; // 경고: 주황
            if (it.current < it.safety * 1.5)   return 'rgba(241,196,15,0.75)'; // 근접: 노랑
            return 'rgba(39,174,96,0.70)';                                        // 정상: 초록
        });

        new Chart(document.getElementById('inventoryStockChart'), {
            type: 'bar',
            data: {
                labels: items.map(function(it) { return it.name; }),
                datasets: [
                    {
                        label: '현재 재고',
                        data: items.map(function(it) { return it.current; }),
                        backgroundColor: bgColors,
                        borderRadius: 4,
                        order: 1
                    },
                    {
                        label: '안전재고',
                        type: 'line',
                        data: items.map(function(it) { return it.safety; }),
                        borderColor: 'rgba(231,76,60,0.9)',
                        borderDash: [5, 3],
                        borderWidth: 2,
                        pointBackgroundColor: 'rgba(231,76,60,0.9)',
                        pointRadius: 4,
                        fill: false,
                        tension: 0,
                        order: 0
                    }
                ]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: { position: 'bottom' },
                    tooltip: {
                        callbacks: {
                            afterBody: function(items) {
                                var raw = items[0].raw;
                                var safety = items[0].dataset.label === '현재 재고'
                                    ? window._invSafety[items[0].dataIndex]
                                    : null;
                                if (safety !== null && raw < safety) return ['⚠ 안전재고 미달'];
                                return [];
                            }
                        }
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { callback: function(v) { return v.toLocaleString(); } }
                    },
                    x: { ticks: { maxRotation: 30, minRotation: 10 } }
                }
            }
        });

        // 툴팁용 safety 배열 전역 저장
        window._invSafety = items.map(function(it) { return it.safety; });
    })();

})();
</script>
}
