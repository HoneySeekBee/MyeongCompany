@page
@model MSMES.Web.Pages.Receiving.IndexModel
@{ ViewData["Title"] = "수입검사"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">수입검사 (입고 검사)</h1>
</div>

<!-- Status KPI cards -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="text-muted small">입고대기</div>
            <div class="h3 fw-bold mb-0 text-secondary">@Model.PendingCount</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="text-muted small">검사중</div>
            <div class="h3 fw-bold mb-0 text-warning">@Model.InspectingCount</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="text-muted small">합격</div>
            <div class="h3 fw-bold mb-0 text-success">@Model.PassedCount</div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm text-center py-3">
            <div class="text-muted small">불합격</div>
            <div class="h3 fw-bold mb-0 text-danger">@Model.FailedCount</div>
        </div>
    </div>
</div>

<!-- Receipts table with collapsible items -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width:30px;"></th>
                        <th>입고번호</th><th>발주번호</th><th>공급업체</th>
                        <th>입고일</th><th>검사자</th><th>상태</th><th>합격수량</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model.Receipts)
                {
                    <tr data-bs-toggle="collapse" data-bs-target="#gr-@r.Id" style="cursor:pointer;">
                        <td><i class="bi bi-chevron-right chevron-icon" id="chev-@r.Id" style="transition:.2s;"></i></td>
                        <td class="fw-medium">@r.ReceiptNo</td>
                        <td class="text-muted small">@r.PurchaseOrderNo</td>
                        <td>@r.SupplierName</td>
                        <td>@r.ReceiptDate.ToString("MM/dd")</td>
                        <td>@(r.InspectorName ?? "-")</td>
                        <td><span class="badge bg-@r.StatusCss">@r.StatusName</span></td>
                        <td>@r.TotalAccepted.ToString("N0")</td>
                    </tr>
                    <tr class="collapse" id="gr-@r.Id">
                        <td colspan="8" class="p-0 bg-light">
                            <table class="table table-sm mb-0">
                                <thead class="table-secondary">
                                    <tr><th>자재코드</th><th>자재명</th><th>발주수량</th><th>입고수량</th><th>검사수량</th><th>합격</th><th>불합격</th><th>불량사유</th></tr>
                                </thead>
                                <tbody>
                                @foreach (var item in r.Items)
                                {
                                    <tr>
                                        <td class="small">@item.MaterialCode</td>
                                        <td>@item.MaterialName</td>
                                        <td>@item.OrderedQty.ToString("N0")</td>
                                        <td>@item.ReceivedQty.ToString("N0")</td>
                                        <td>@item.InspectedQty.ToString("N0")</td>
                                        <td class="text-success fw-semibold">@item.AcceptedQty.ToString("N0")</td>
                                        <td class="@(item.RejectedQty > 0 ? "text-danger fw-semibold" : "")">@item.RejectedQty.ToString("N0")</td>
                                        <td class="small text-muted">@item.DefectReason</td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </td>
                    </tr>
                }
                @if (!Model.Receipts.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-5">입고 데이터가 없습니다.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
document.querySelectorAll('[data-bs-toggle="collapse"]').forEach(row => {
    row.addEventListener('click', function() {
        const target = this.dataset.bsTarget;
        const chevron = document.querySelector('#chev-' + target.replace('#gr-',''));
        const isShown = document.querySelector(target).classList.contains('show');
        chevron.style.transform = isShown ? 'rotate(0deg)' : 'rotate(90deg)';
    });
});
</script>
